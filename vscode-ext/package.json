{
  "name": "mosaic-schematic",
  "displayName": "Mosaic Schematic Editor",
  "description": "Visual schematic editor for analog IC design",
  "version": "1.16.2",
  "publisher": "nyancad",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NyanCAD/Mosaic"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./out/main.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "Mosaic.schematic",
        "displayName": "Mosaic Schematic",
        "selector": [
          {
            "filenamePattern": "*.nyancir"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "Mosaic.library",
        "displayName": "Mosaic Library",
        "selector": [
          {
            "filenamePattern": "models.nyanlib"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Mosaic",
      "properties": {
        "mosaic.pythonCommand": {
          "type": "string",
          "default": "uv run --with nyancad-server",
          "description": "Command prefix for running Python tools (e.g., 'uv run --with nyancad-server', or path to venv python)"
        }
      }
    },
    "commands": [
      {
        "command": "Mosaic.schematic.new",
        "title": "Mosaic: Create New Schematic"
      }
    ]
  },
  "dependencies": {}
}
